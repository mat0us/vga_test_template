install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/ex_01/bin || mkdir -p $(INSTALL_ROOT)/opt/ex_01/bin
	$(DEL_FILE) -r $(INSTALL_ROOT)/opt/ex_01/bin/ex_01.app
	
	$(QINSTALL) ex_01.app $(INSTALL_ROOT)/opt/ex_01/bin/ex_01.app

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/opt/ex_01/bin/ex_01.app
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/ex_01/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

